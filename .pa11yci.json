{
    "defaults": {
        "standard": "WCAG2AA",
        "runners": ["axe"],
        "timeout": 30000,
        "chromeLaunchConfig": { "args": ["--no-sandbox", "--disable-gpu"] }
    },
    "urls": [
        "http://127.0.0.1:8000/",
        "http://127.0.0.1:8000/login",
        "http://127.0.0.1:8000/register",
        "http://127.0.0.1:8000/forgot-password",
        {
            "url": "http://127.0.0.1:8000/welcome",
            "actions": [
                "navigate to http://127.0.0.1:8000/login",
                "set field #email to demo@example.com",
                "set field #password to password",
                "click element button[type=submit]",
                "wait for element a[href$='/dashboard'] to be visible",
                "navigate to http://127.0.0.1:8000/welcome",
                "wait for element form[action$='/welcome'] button to be visible"
            ]
        }
    ]
}
